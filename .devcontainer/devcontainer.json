{
  "name": "quarto-odyssey",
  "image": "ghcr.io/rocker-org/devcontainer/tidyverse:4.5",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "configureZshAsDefaultShell": false,
      "upgradePackages": false
    },
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
      "version": "release",
      "installTinyTex": true
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "quarto.quarto",
        "reditorsupport.r",
        "rdebugger.r-debugger",
        "tomoki1207.pdf"
      ],
      "settings": {
        "editor.formatOnSave": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "security.workspace.trust.enabled": false,
        "task.allowAutomaticTasks": "on",
        "r.rterm.linux": "/usr/local/bin/R",
        "r.bracketedPaste": true,
        "[r]": {
          "editor.wordSeparators": "`~!@#%$^&*()-=+[{]}\\|;:'\",<>/?"
        }
      }
    },
    "codespaces": {
      "openFiles": [
        "course/course.qmd",
        "exercises/02-quarto-analysis/template/manuscript.qmd"
      ]
    }
  },
  "postCreateCommand": "R -q -e 'p <- c(\"tidyverse\",\"gt\",\"ggplot2\",\"knitr\",\"rmarkdown\"); m <- setdiff(p, rownames(installed.packages())); if (length(m)) install.packages(m, repos=\"https://cloud.r-project.org\") else cat(\"All required R packages already present\\n\")'"
}
